#!/bin/sh

echo "Formulieren importeren..."

py -3 importeer_formulieren.py
RESULT=$?

if [ $RESULT -ne 0 ]; then
    echo "Importeren mislukt. Commit wordt afgebroken."
    exit 1
fi

git add data/voorspellingen.csv
git add data/import_fouten.csv 2>/dev/null

echo "Voorspellingen bijgewerkt."
exit 0